# Frontend
# Leave blank to use same-origin /api/* rewrites through Next.js.
NEXT_PUBLIC_API_URL=

# Backend
DATABASE_URL=sqlite:///./research-notebook.db
ENVIRONMENT=development

# Required — Google Gemini API key for AI paper analysis
GEMINI_API_KEY=

# Optional — required for "Open in Colab" button (creates private GitHub Gists)
GITHUB_TOKEN=

# AWS deployment
AWS_REGION=us-east-1
TF_VAR_app_name=research-notebook
TF_VAR_environment=prod
TF_VAR_database_url=
TF_VAR_desired_count=1
